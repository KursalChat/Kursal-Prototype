<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Kursal</string>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Kursal Contact Export</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>chat.kursal.contact</string>
			</array>
		</dict>
	</array>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0.0</string>
	<key>CFBundleVersion</key>
	<string>1.0.0</string>
	<key>ITSAppUsesNonExemptEncryption</key>
	<true/>
	<key>ITSEncryptionExportComplianceCode</key>
	<string></string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoadsInWebContent</key>
		<true/>
	</dict>
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Kursal uses Bluetooth to discover nearby devices</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_p2p._udp</string>
		<string>_p2p._tcp</string>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>Kursal uses the camera to scan QR codes when adding a new contact.</string>
	<key>NSDesktopFolderUsageDescription</key>
	<string>Kursal saves received files to your Desktop when you choose it.</string>
	<key>NSDocumentsFolderUsageDescription</key>
	<string>Kursal reads files you pick so you can send them, and writes files you receive.</string>
	<key>NSDownloadsFolderUsageDescription</key>
	<string>Kursal saves received files to your Downloads folder.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>Kursal uses Face ID to unlock the app.</string>
	<key>NSLocalNetworkUsageDescription</key>
	<string>Kursal uses your local network to discover nearby peers for direct, encrypted peer-to-peer messaging.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Kursal uses the microphone only during voice calls with your contacts.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Kursal may save received images to your photo library.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Kursal needs access to your photos so you can pick a profile picture.</string>
	<key>NSRequiresAquaSystemAppearance</key>
	<false/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
		<string>metal</string>
	</array>
	<key>UIStatusBarStyle</key>
	<string>UIStatusBarStyleDefault</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
	</array>
	<key>UIViewControllerBasedStatusBarAppearance</key>
	<true/>
	<key>UTExportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
			<key>UTTypeDescription</key>
			<string>Kursal contact export file</string>
			<key>UTTypeIdentifier</key>
			<string>chat.kursal.contact</string>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>kursal</string>
				</array>
				<key>public.mime-type</key>
				<array>
					<string>application/octet-stream</string>
				</array>
			</dict>
		</dict>
	</array>
</dict>
</plist>