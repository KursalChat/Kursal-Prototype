{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:write-files",
    "fs:read-all",
    "fs:allow-stat",
    "opener:default",
    "clipboard-manager:default",
    "core:window:allow-set-badge-count",
    "os:default"
  ]
}
